{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DTPF Agent",
  "version": "1.0.1",
  "identifier": "com.dtpf.agent",
  "build": {
    "beforeDevCommand": "pnpm --filter sticky-note-ui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter sticky-note-ui build",
    "frontendDist": "../ui/sticky-note/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DTPF Agent",
        "width": 1,
        "height": 1,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "tooltip": "DTPF Agent"
    },
    "security": {
      "csp": null,
      "capabilities": ["default", "sticky-windows"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/Parthmh361/Desktop-Task-Presence-Framework/releases/latest/download/latest.json"],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyOEJFQjJDQ0QzM0QwNTUKUldSVjBEUE5MT3VMZ25Fa1JPNWpSWldRZUdWYXJQZkN4YUkyaEZXYlBRQ0hTNWd1Qk9ZRmNBekoK"
    }
  }
}
