{
  "name": "@dtpf/sdk-vanilla",
  "version": "1.0.0",
  "description": "Vanilla JS SDK for Desktop Task Presence Framework",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "echo 'No tests yet'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dtpf/sdk-core": "workspace:*",
    "@dtpf/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@dtpf/eslint-config": "workspace:*",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
