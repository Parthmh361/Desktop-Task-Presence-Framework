{
  "name": "@dtpf/sdk-react",
  "version": "1.0.0",
  "description": "React hooks and context for DTPF",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@dtpf/sdk-core": "workspace:*",
    "@dtpf/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@dtpf/eslint-config": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.18",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.17.0",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
